# Contact form — sign up free at formspree.io, create a form, paste the ID here
# If left empty, the form falls back to opening a mailto: link
NEXT_PUBLIC_FORMSPREE_ID=your_form_id_here

# WhatsApp number in international format, no + or spaces (e.g. 972501234567 for 050-123-4567)
NEXT_PUBLIC_WHATSAPP_NUMBER=your_whatsapp_number_here

# Contact email shown as a fallback option in the contact section
NEXT_PUBLIC_EMAIL=your_email_here

# Public site URL (no trailing slash) — used for canonical URLs, hreflang, OG and JSON-LD.
# e.g. https://noambukobza.dev. Falls back to http://localhost:3000 if unset.
NEXT_PUBLIC_SITE_URL=https://your-domain.example
